# One token, or comma-separated tokens if several @bots open the same Mini App (e.g. EthioAdda + Habesha).
# The first token is used for running bot/bot.py (polling); WebApp auth tries every token.
BOT_TOKEN="8753057521:AAHlSlZUj-RRG0t3yL3MQ2MSiCzKF-GIatw"

# Telegram Mini App *top bar* title is usually the short name in @BotFather:
# My Bots ? your bot ? Bot Settings ? Configure Mini App ? set Short name to "ETHIO BINGO" (not only this repo).
#
# Public base URL of your FastAPI server (must be reachable by Telegram WebApp).
# Example: https://1234abcd.ngrok-free.app
# Quick tunnels (cloudflared without a Cloudflare account): the *.trycloudflare.com hostname
# changes every time you restart cloudflared — copy the new URL from the terminal into WEBAPP_URL and restart the bot/API.
WEBAPP_URL=https://bingo-1-m76q.onrender.com

# Comma-separated Telegram user IDs of admins allowed to deposit.
ADMIN_TELEGRAM_IDS="6694873823"
#
# Admin manual credit (no Telebirr SMS): in Telegram with the bot, run
#   /addbalance <telegram_user_id> <amount_etb> [note]
# or /admin_deposit (same). Numeric id credits even if the user never messaged the bot.
# @username works only if they used /start once so their handle is in the database.
# Phone: use Telebirr-style number; we match users who already used that number on /withdraw (stored as telebirr_phone_key).

# Optional: Telegram user ID that receives the 20% house cut on each winning round (withdrawable balance).
# If unset, the smallest ID in ADMIN_TELEGRAM_IDS is used. Required when OWNER_RAKE_FRACTION > 0.
# OWNER_TELEGRAM_USER_ID="123456789"

# Where to store SQLite DB file.
DATABASE_URL="postgresql://bingo1_user:IMI5jVPEqdFJYtFHVbFw93WxQuk9dSmM@dpg-d757vofpm1nc739aor10-a/bingo1"

# House take from total stakes when someone wins (0.2 = 20%). Winner receives the rest. Set to 0 to disable.
