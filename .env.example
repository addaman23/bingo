# Pause (seconds) after lobby countdown hits zero before the first ball is called.
# POST_LOBBY_FIRST_CALL_DELAY_SEC="3"

# For demo game defaults
DEFAULT_CALL_INTERVAL_SEC="2"
DEFAULT_WIN_MULTIPLIER="2.0"
